# ================================
# CONFIGURAÇÃO
# ================================
$source = "C:\Users"
$destination = "\\SERVIDOR\Backup"
$logDir = "C:\Backup\logs"
$date = Get-Date -Format "yyyy-MM-dd_HH-mm"
$logFile = "$logDir\backup.log"

# ================================
# PREPARAÇÃO
# ================================
if (!(Test-Path $logDir)) {
    New-Item -ItemType Directory -Path $logDir -Force
}

$destFolder = "$destination\Backup_$date"

if (!(Test-Path $destFolder)) {
    New-Item -ItemType Directory -Path $destFolder -Force
}

# ================================
# INÍCIO DO LOG
# ================================
Add-Content $logFile "==============================="
Add-Content $logFile "Início do backup: $date"

# ================================
# EXECUÇÃO DO BACKUP
# ================================
robocopy $source $destFolder `
/E `
/Z `
/XO `
/R:3 `
/W:5 `
/MT:8 `
/XD "AppData" "Temp" "Cache" `
/LOG+:$logFile

# ================================
# VALIDAÇÃO
# ================================
if ($LASTEXITCODE -le 3) {
    Add-Content $logFile "[$date] Backup concluído com sucesso"
} else {
    Add-Content $logFile "[$date] ERRO no backup - código $LASTEXITCODE"
}

Add-Content $logFile "Fim do backup"

# Remover backups com mais de 7 dias
Get-ChildItem $destination -Directory |
Where-Object { $_.CreationTime -lt (Get-Date).AddDays(-7) } |
Remove-Item -Recurse -Force
Get-ChildItem $destination -Directory |
Where-Object { $_.CreationTime -lt (Get-Date).AddDays(-7) } |
Remove-Item -Recurse -Force

if (!(Test-Path $destination)) {
    Add-Content $logFile "Servidor não acessível"
    exit
}

# ================================
# FUNÇÃO DE LOG
# ================================
function Write-Log {
    param (
        [string]$Message,
        [string]$Level = "INFO"
    )

    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $logEntry = "[$timestamp] [$Level] $Message"

    Add-Content -Path $logFile -Value $logEntry

    # Exibir no console
    if ($Level -eq "ERROR") {
        Write-Host $logEntry -ForegroundColor Red
    }
    elseif ($Level -eq "WARNING") {
        Write-Host $logEntry -ForegroundColor Yellow
    }
    else {
        Write-Host $logEntry -ForegroundColor Green
    }
}

Add-Type -AssemblyName PresentationFramework
[System.Windows.MessageBox]::Show("Backup concluído com sucesso")
