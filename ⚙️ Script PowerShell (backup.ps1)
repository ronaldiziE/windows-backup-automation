# ============================================
# CONFIGURAÇÕES
# ============================================

$source      = "C:\Users\Public\Documents"     # Origem
$destination = "\\Servidor\Backup"             # Destino (rede)
$logDir      = "C:\BackupLogs"                 # Pasta de logs
$retentionDays = 7                             # Dias para retenção
$enablePopup = $true                           # Ativar alerta visual

# Criar pasta de log se não existir
if (!(Test-Path $logDir)) {
    New-Item -ItemType Directory -Path $logDir | Out-Null
}

$logFile = Join-Path $logDir "backup.log"

# Timestamp para pasta de backup
$timestamp = Get-Date -Format "yyyy-MM-dd_HH-mm-ss"
$destFolder = Join-Path $destination $timestamp

# ============================================
# FUNÇÃO DE LOG
# ============================================

function Write-Log {
    param (
        [string]$Message,
        [string]$Level = "INFO"
    )

    $timestampLog = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $logEntry = "[$timestampLog] [$Level] $Message"

    Add-Content -Path $logFile -Value $logEntry

    switch ($Level) {
        "ERROR"   { Write-Host $logEntry -ForegroundColor Red }
        "WARNING" { Write-Host $logEntry -ForegroundColor Yellow }
        default   { Write-Host $logEntry -ForegroundColor Green }
    }
}

# ============================================
# INÍCIO
# ============================================

Write-Log "=============================="
Write-Log "Iniciando rotina de backup"

# Validar origem
if (!(Test-Path $source)) {
    Write-Log "Origem não encontrada: $source" "ERROR"
    exit 1
}

# Validar destino (rede)
if (!(Test-Path $destination)) {
    Write-Log "Destino não acessível: $destination" "ERROR"
    exit 2
}

# Criar pasta de destino com timestamp
try {
    New-Item -ItemType Directory -Path $destFolder -Force | Out-Null
    Write-Log "Pasta criada: $destFolder"
}
catch {
    Write-Log "Erro ao criar pasta de destino" "ERROR"
    exit 3
}

# ============================================
# EXECUÇÃO DO BACKUP (ROBOCOPY)
# ============================================

Write-Log "Executando Robocopy..."

robocopy $source $destFolder `
/E `
/Z `
/XO `
/R:3 `
/W:5 `
/MT:8 `
/XD "AppData" "Temp" "Cache" `
/LOG+:$logFile

# ============================================
# VALIDAÇÃO RESULTADO
# ============================================

if ($LASTEXITCODE -le 3) {
    Write-Log "Backup concluído com sucesso"
}
else {
    Write-Log "Erro no backup. Código: $LASTEXITCODE" "ERROR"

    if ($enablePopup) {
        Add-Type -AssemblyName PresentationFramework
        [System.Windows.MessageBox]::Show("Erro no backup! Verifique o log.")
    }

    exit 4
}

# ============================================
# LIMPEZA (RETENÇÃO)
# ============================================

Write-Log "Aplicando política de retenção ($retentionDays dias)..."

try {
    Get-ChildItem $destination -Directory |
    Where-Object { $_.CreationTime -lt (Get-Date).AddDays(-$retentionDays) } |
    ForEach-Object {
        Remove-Item $_.FullName -Recurse -Force
        Write-Log "Removido backup antigo: $($_.FullName)" "WARNING"
    }
}
catch {
    Write-Log "Erro na limpeza de backups antigos" "WARNING"
}

# ============================================
# FINALIZAÇÃO
# ============================================

Write-Log "Rotina finalizada com sucesso"
Write-Log "=============================="

# Alerta de sucesso (opcional)
if ($enablePopup) {
    Add-Type -AssemblyName PresentationFramework
    [System.Windows.MessageBox]::Show("Backup concluído com sucesso!")
}
